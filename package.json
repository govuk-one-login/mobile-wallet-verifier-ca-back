{
  "name": "mobile-wallet-verifier-ca-back",
  "version": "1.0.0",
  "description": "Mobile wallet verifier CA backend services",
  "type": "module",
  "scripts": {
    "postinstall": "husky || true",
    "build": "mkdir -p dist && cp -f open-api-spec.yaml dist/ && node build.mjs",
    "test": "./node_modules/.bin/vitest run",
    "test:cov": "./node_modules/.bin/vitest run --coverage",
    "lint": "./node_modules/.bin/eslint .",
    "format": "./node_modules/.bin/prettier --write '**/*.{json,md,ts}'",
    "format:check": "./node_modules/.bin/prettier --check '**/*.{json,md,ts}'",
    "infra:format:check": "rain fmt --verify application.yaml",
    "infra:format": "rain fmt --write application.yaml",
    "test:integration": "./node_modules/@cucumber/cucumber/bin/cucumber.js"
  },
  "license": "MIT",
  "dependencies": {
    "@aws-lambda-powertools/logger": "^2.33.0",
    "@aws-sdk/client-dynamodb": "^3.1030.0",
    "@aws-sdk/client-secrets-manager": "^3.1030.0",
    "@peculiar/asn1-android": "^2.3.8",
    "@peculiar/asn1-schema": "^2.3.8",
    "@peculiar/webcrypto": "1.5.0",
    "@peculiar/x509": "2.0.0",
    "esbuild": "^0.28.0",
    "jose": "^6.2.2",
    "jsonwebtoken": "^9.0.3",
    "pkijs": "^3.4.0"
  },
  "engines": {
    "node": ">=22.0.0 <23.0.0"
  },
  "devDependencies": {
    "@cucumber/cucumber": "^12.8.1",
    "@eslint/js": "^9.39.2",
    "@types/aws-lambda": "^8.10.161",
    "@types/js-yaml": "^4.0.9",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.19.17",
    "@vitest/coverage-v8": "^4.1.4",
    "eslint": "^10.2.0",
    "glob": "^13.0.6",
    "husky": "^9.1.7",
    "jiti": "^2.6.1",
    "js-yaml": "^4.1.1",
    "prettier": "^3.8.3",
    "ts-node": "^10.9.2",
    "tsx": "^4.20.6",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.2",
    "vitest": "^4.0.15"
  }
}
